    def validate(self):
        if self.auto_otaa.get():
            if not self.dev_eui.get().strip() or len(sanitize_hex(self.dev_eui.get())) != 16:
                self.dev_eui.set(random_hex(8))
            if not self.app_eui.get().strip():
                self.app_eui.set("0000000000000000")
            if not self.app_key.get().strip() or len(sanitize_hex(self.app_key.get())) != 32:
                self.app_key.set(random_hex(16))

        node_id = self.node_id.get().strip()
        if not node_id.isdigit():
            raise ValueError("Node ID debe ser numérico.")

        if not self.band_mac.get().strip():
            raise ValueError("Debes asignar la MAC de la banda cardiaca. En esta versión la Heltec no conecta por nombre/prefijo.")

        if not MAC_RE.fullmatch(self.band_mac.get().strip()):
            raise ValueError("MAC banda debe tener formato AA:BB:CC:DD:EE:FF.")

        period = self.period_ms.get().strip()
        if not period.isdigit() or int(period) < 1000:
            raise ValueError("Periodo de envío debe ser un número >= 1000 ms.")

        fport = self.ug65_fport.get().strip()
        if not fport.isdigit() or int(fport) < 1 or int(fport) > 223:
            raise ValueError("FPort UG65 debe ser un número entre 1 y 223.")

        timeout = self.ug65_timeout.get().strip()
        if not timeout.isdigit() or int(timeout) < 1:
            raise ValueError("Timeout UG65 debe ser un número mayor a 0.")

        if not self.ug65_application.get().strip():
            raise ValueError("Application UG65 no puede estar vacía.")

        if not self.ug65_deviceprofile.get().strip():
            raise ValueError("Device Profile UG65 no puede estar vacío.")

        dev_eui = validate_hex(self.dev_eui.get(), 8, "DevEUI")
        app_eui = validate_hex(self.app_eui.get(), 8, "AppEUI/JoinEUI")
        app_key = validate_hex(self.app_key.get(), 16, "AppKey")
        return node_id, dev_eui, app_eui, app_key

    def build_code(self):
        node_id, dev_eui, app_eui, app_key = self.validate()
        data = {
            "NODE_ID": node_id,
            "PERSON_NAME": self.person_name.get().strip(),
            "BAND_NAME": self.band_name.get().strip(),
            "BAND_MAC": self.band_mac.get().strip().upper(),
            "BAND_NAME_PREFIX": self.band_prefix.get().strip(),
            "BLE_SELF_NAME": self.ble_self_name.get().strip(),
            "APP_TX_MS": self.period_ms.get().strip(),
            "DEVEUI": hex_to_c_array(dev_eui),
            "APPEUI": hex_to_c_array(app_eui),
            "APPKEY": hex_to_c_array(app_key),
        }
        
        code = SKETCH_TEMPLATE
        for key, value in data.items():
            code = code.replace(f"{{{key}}}", str(value))
            
        return code, dev_eui, app_eui, app_key

    def generate(self):
        try:
            base = Path(self.output_dir.get().strip() or Path.cwd())
            csv_path = base / "nodes.csv"

            # CLAVE PARA PRODUCCIÓN: cada sketch nuevo recibe DevEUI y AppKey únicos.
            # Se valida contra nodes.csv para no repetir credenciales ya generadas.
            if self.auto_otaa.get() and self.force_unique_otaa.get():
                self.ensure_unique_otaa_credentials(csv_path)

            code, dev_eui, app_eui, app_key = self.build_code()
            node_id = self.node_id.get().strip()
            
            filename = self.output_filename.get().strip() or f"Minerguard_{node_id}.ino"
            if not filename.lower().endswith(".ino"):
                filename += ".ino"

            # Arduino IDE exige que la carpeta del sketch tenga el mismo nombre que el .ino.
            # Esto evita el aviso: "The file needs to be inside a sketch folder named ...".
            outdir = base / Path(filename).stem
            outdir.mkdir(parents=True, exist_ok=True)

            ino_path = outdir / filename

            # IMPORTANTE: Arduino IDE compila TODOS los .ino/.cpp/.h que existan
            # dentro de la carpeta del sketch. Esta plantilla SÍ necesita display.cpp
            # y display.h, por eso los sobrescribimos con la versión correcta.
            # También evitamos dejar sketches .ino antiguos dentro de la misma carpeta,
            # porque Arduino puede abrirlos como pestañas del mismo proyecto.
            for old_ino in outdir.glob("*.ino"):
                if old_ino.name != filename:
                    try:
                        old_ino.unlink()
                    except Exception as e:
                        self.write_log(f"Aviso: no se pudo eliminar {old_ino}: {e}")

            ino_path.write_text(code, encoding="utf-8")
            (outdir / "display.cpp").write_text(DISPLAY_CPP_TEMPLATE, encoding="utf-8")
            (outdir / "display.h").write_text(DISPLAY_H_TEMPLATE, encoding="utf-8")

            # CAPTURAMOS LA FECHA Y HORA ACTUAL DEL COMPUTADOR
            timestamp_actual = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

            row = {
                "node_id": node_id,
                "person": self.person_name.get().strip(),
                "devEUI": dev_eui,
                "appEUI": app_eui,
                "appKey": app_key,
                "band_prefix": self.band_prefix.get().strip(),
                "band_name": self.band_name.get().strip(),
                "band_mac": self.band_mac.get().strip().upper(),
                "ble_self_name": self.ble_self_name.get().strip(),
                "period_ms": self.period_ms.get().strip(),
                "sketch_path": str(ino_path),
                "creation_date": timestamp_actual, # SE AÑADE AL DICCIONARIO
            }
            self.save_csv(csv_path, row)

            ug65_csv_path = base / "ug65_bulk_import_devices.csv"
            self.save_ug65_bulk_csv(ug65_csv_path, node_id, self.person_name.get().strip(), dev_eui, app_key)

            summary = (
                f"Sketch generado correctamente el {timestamp_actual}.\n"
                f"Carpeta: {outdir}\n"
                f"Archivo: {ino_path.name}\n"
                f"Auxiliares: display.cpp, display.h\n"
                f"Banda MAC exclusiva: {self.band_mac.get().strip().upper()}\n"
                f"Convencion beacons: Major = nivel / Minor = PK\n"
                f"DevEUI: {dev_eui}\n"
                f"AppEUI: {app_eui}\n"
                f"AppKey: {app_key}\n"
                f"CSV interno: {csv_path}\n"
                f"CSV UG65 import: {ug65_csv_path}\n"
            )
            self.write_log(summary)
            messagebox.showinfo("Listo", f"Sketch generado en:\n{ino_path}")
        except Exception as e:
            messagebox.showerror("Error", str(e))
            self.write_log(f"ERROR: {e}")

    def save_csv(self, csv_path: Path, row: dict):
        file_exists = csv_path.exists()
        with csv_path.open("a", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=list(row.keys()))
            if not file_exists:
                writer.writeheader()
            writer.writerow(row)

    def save_ug65_bulk_csv(self, csv_path: Path, node_id: str, person: str, dev_eui: str, app_key: str):
        """Crea/agrega una fila al CSV de importación masiva del UG65 Milesight.

        Formato basado en el CSV exportado por el UG65:
        name,description,deveui,deviceprofile,application,payloadcodec,fport,appkey,devaddr,nwkskey,appskey,timeout
        """
        headers = [
            "name",
            "description",
            "deveui",
            "deviceprofile",
            "application",
            "payloadcodec",
            "fport",
            "appkey",
            "devaddr",
            "nwkskey",
            "appskey",
            "timeout",
        ]

        row = {
            "name": str(node_id).strip(),
            "description": person.strip(),
            "deveui": sanitize_hex(dev_eui).lower(),
            "deviceprofile": self.ug65_deviceprofile.get().strip(),
            "application": self.ug65_application.get().strip(),
            "payloadcodec": "",
            "fport": self.ug65_fport.get().strip(),
            "appkey": sanitize_hex(app_key).lower(),
            "devaddr": "",
            "nwkskey": "",
            "appskey": "",
            "timeout": self.ug65_timeout.get().strip(),
        }

        file_exists = csv_path.exists()
        with csv_path.open("a", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=headers)
            if not file_exists:
                writer.writeheader()
            writer.writerow(row)

    def open_output(self):
        folder = Path(self.output_dir.get().strip() or Path.cwd())
        if not folder.exists():
            folder.mkdir(parents=True, exist_ok=True)
