/* =========================================================
   PARSER Y AUXILIARES BLE (INTACTO)
   ========================================================= */
static uint8_t parse_hr_2a37(const uint8_t* data, uint16_t len) {
  if (len < 2) return 0;
  uint8_t flags = data[0];
  if ((flags & 0x01) == 0) return data[1];
  if (len >= 3) {
    uint16_t hr = (uint16_t)data[1] | ((uint16_t)data[2] << 8);
    return (hr > 255) ? 255 : (uint8_t)hr;
  }
  return 0;
}

static bool uuidMatches(const uint8_t* uuid16) { return memcmp(uuid16, MINERGUARD_UUID, 16) == 0; }
static uint8_t encodeRSSI(int8_t rssi) { int16_t v = (int16_t)rssi + 128; if (v < 0) v = 0; if (v > 255) v = 255; return (uint8_t)v; }

/* =========================================================
   LOGICA BEACONS (INTACTO)
   ========================================================= */
static void cleanupOldBeacons() {
  uint32_t now = millis();
  for (int i = 0; i < 3; i++) {
    if (topBeacons[i].valid && (now - topBeacons[i].seenAt > BEACON_TIMEOUT_MS)) {
      topBeacons[i].valid = false; topBeacons[i].rssi = -127;
    }
  }
}

static void sortTopBeacons() {
  for (int i = 0; i < 2; i++) {
    for (int j = i + 1; j < 3; j++) {
      if (!topBeacons[i].valid && topBeacons[j].valid) {
        BeaconReading tmp = topBeacons[i]; topBeacons[i] = topBeacons[j]; topBeacons[j] = tmp;
      } else if (topBeacons[i].valid && topBeacons[j].valid && topBeacons[j].rssi > topBeacons[i].rssi) {
        BeaconReading tmp = topBeacons[i]; topBeacons[i] = topBeacons[j]; topBeacons[j] = tmp;
      }
    }
  }
}

static void updateTopBeacon(uint16_t major, uint16_t minor, int8_t rssi) {
  uint32_t now = millis();
  bool updated = false;
  
  for (int i = 0; i < 3; i++) {
    if (topBeacons[i].valid && topBeacons[i].major == major && topBeacons[i].minor == minor) {
      float smoothed_rssi = (topBeacons[i].rssi * 0.7) + (rssi * 0.3);
      topBeacons[i].rssi = (int8_t)smoothed_rssi;
      topBeacons[i].seenAt = now;
      updated = true;
      break;
    }
  }

  if (!updated) {
    for (int i = 0; i < 3; i++) {
      if (!topBeacons[i].valid) {
        topBeacons[i].valid = true; topBeacons[i].major = major; topBeacons[i].minor = minor;
        topBeacons[i].rssi = rssi; topBeacons[i].seenAt = now; updated = true; break;
      }
    }
  }

  if (!updated) {
    int worst = 0;
    for (int i = 1; i < 3; i++) { if (topBeacons[i].rssi < topBeacons[worst].rssi) worst = i; }
    if (rssi > (topBeacons[worst].rssi + 3)) {
      topBeacons[worst].major = major; topBeacons[worst].minor = minor; topBeacons[worst].rssi = rssi;
      topBeacons[worst].seenAt = now; topBeacons[worst].valid = true;
    }
  }

  sortTopBeacons();
  updateDisplayPosition();
}

static bool parseIBeacon(const ble_gap_evt_adv_report_t* report, uint16_t& major, uint16_t& minor) {
  uint8_t buffer[31] = {0};
  int len = Bluefruit.Scanner.parseReportByType(report, BLE_GAP_AD_TYPE_MANUFACTURER_SPECIFIC_DATA, buffer, sizeof(buffer));
  if (len < 25 || buffer[0] != 0x4C || buffer[1] != 0x00 || buffer[2] != 0x02 || buffer[3] != 0x15) return false;
  if (!uuidMatches(&buffer[4])) return false;
  major = ((uint16_t)buffer[20] << 8) | buffer[21]; minor = ((uint16_t)buffer[22] << 8) | buffer[23];
  return true;
}

/* =========================================================
   CALLBACKS BLE 
   ========================================================= */
void hr_notify_cb(BLEClientCharacteristic*, uint8_t* data, uint16_t len) {
  uint8_t bpm = parse_hr_2a37(data, len);
  if (bpm > 0) { hrBpm = bpm; hrValid = true; updateDisplayPosition(); }
}

void bat_notify_cb(BLEClientCharacteristic*, uint8_t* data, uint16_t len) {
  if (len >= 1) { bandBatPct = data[0]; bandBatValid = true; }
}

static bool match_band_by_mac(const char* mac) {
  // Seguridad: si no hay MAC configurada en el generador, no se conecta a ninguna banda.
  if (!BAND_MAC_TARGET[0] || !mac || !mac[0]) return false;

  // Comparación exacta, sin distinguir mayúsculas/minúsculas.
  // Formato esperado: AA:BB:CC:DD:EE:FF
  return strcasecmp(BAND_MAC_TARGET, mac) == 0;
}

void connect_cb(uint16_t conn_handle) {
  bleConnected = true;
  requestScreenUpdate("Banda Conectada", "Sincronizando...", PERSON_NAME, CLR_LIME);
  if (svcHR.discover(conn_handle) && chrHR.discover()) { chrHR.setNotifyCallback(hr_notify_cb); chrHR.enableNotify(); }
  if (svcBAT.discover(conn_handle) && chrBAT.discover()) {
    chrBAT.setNotifyCallback(bat_notify_cb); chrBAT.enableNotify();
    uint8_t v = 0; if (chrBAT.read(&v, 1)) { bandBatPct = v; bandBatValid = true; }
  }
}

void disconnect_cb(uint16_t, uint8_t) {
  bleConnected = false; hrValid = false; bandBatValid = false;
  hideHeartbeat();
  requestScreenUpdate("Banda desconecta", "Reintentando...", PERSON_NAME, CLR_RED);
  Bluefruit.Scanner.start(0);
}

void scan_cb(ble_gap_evt_adv_report_t* report) {
  uint16_t major = 0, minor = 0;
  if (parseIBeacon(report, major, minor)) updateTopBeacon(major, minor, report->rssi);

  char macbuf[18] = {0};
  uint8_t const* a = report->peer_addr.addr;
  snprintf(macbuf, sizeof(macbuf), "%02X:%02X:%02X:%02X:%02X:%02X", a[5], a[4], a[3], a[2], a[1], a[0]);

  // Conexión exclusiva por MAC asignada en el generador.
  // No se acepta prefijo/nombre para evitar conectarse a otra banda cercana.
  if (!bleConnected && match_band_by_mac(macbuf)) {
    Bluefruit.Central.connect(report);
    return;
  }

  Bluefruit.Scanner.resume();
}

/* =========================================================
   PAYLOAD EXTENDIDO LORAWAN (36 BYTES)
   Beacons: Major(nivel), Minor(PK), RSSI
   ========================================================= */
static void build_extended_payload(uint8_t* out, uint8_t& sz, bool panic) {
  Bluefruit.Scanner.stop();
  cleanupOldBeacons(); sortTopBeacons();

  memcpy(snapshotB, topBeacons, sizeof(topBeacons));

  uint8_t flags = 0;
  if (panic) flags |= 0x01;
  if (hrValid) flags |= 0x02;
  if (bandBatValid) flags |= 0x04;
  if (bleConnected) flags |= 0x08; 

  uint16_t nodeId = {NODE_ID};
  out[0] = flags; out[1] = hrValid ? hrBpm : 0; out[2] = bandBatValid ? bandBatPct : 0;
  out[3] = (uint8_t)(nodeId & 0xFF); out[4] = (uint8_t)((nodeId >> 8) & 0xFF); out[5] = bleConnected ? 1 : 0;

  for (int i = 0; i < 3; i++) {
    int base = 6 + (i * 5);
    if (snapshotA[i].valid) {
      // Orden de bytes por beacon: Major(nivel), Minor(PK), RSSI codificado.
      out[base+0] = (uint8_t)((snapshotA[i].major >> 8) & 0xFF); out[base+1] = (uint8_t)(snapshotA[i].major & 0xFF);
      out[base+2] = (uint8_t)((snapshotA[i].minor >> 8) & 0xFF); out[base+3] = (uint8_t)(snapshotA[i].minor & 0xFF);
      out[base+4] = encodeRSSI(snapshotA[i].rssi);
    } else { memset(&out[base], 0, 5); }
  }

  for (int i = 0; i < 3; i++) {
    int base = 21 + (i * 5);
    if (snapshotB[i].valid) {
      // Orden de bytes por beacon: Major(nivel), Minor(PK), RSSI codificado.
      out[base+0] = (uint8_t)((snapshotB[i].major >> 8) & 0xFF); out[base+1] = (uint8_t)(snapshotB[i].major & 0xFF);
      out[base+2] = (uint8_t)((snapshotB[i].minor >> 8) & 0xFF); out[base+3] = (uint8_t)(snapshotB[i].minor & 0xFF);
      out[base+4] = encodeRSSI(snapshotB[i].rssi);
    } else { memset(&out[base], 0, 5); }
  }

  sz = 36;
  lastPeriodicSend = millis(); 
  snapshotATaken = false; 

  Bluefruit.Scanner.start(0);
}

static void prepareTxFrame(uint8_t port) {
  (void)port; uint8_t sz = 0;
  build_extended_payload(appData, sz, panicActive); appDataSize = sz;
}

