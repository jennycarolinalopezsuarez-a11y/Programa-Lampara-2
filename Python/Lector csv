    @staticmethod
    def valor_limpio(valor):
        if valor is None:
            return ""
        valor = str(valor).strip()
        if valor.upper() in {"N/A", "NULL", "NONE", "-"}:
            return ""
        return valor

    @staticmethod
    def parsear_nombre_completo(nombre_completo):
        """
        Convierte `person` en nombres/apellidos.
        Heurística pensada para nombres chilenos:
        - 1 palabra: nombres = palabra, apellidos = ""
        - 2 palabras: nombres = primera, apellidos = segunda
        - 3 palabras: nombres = primera, apellidos = últimas dos
        - 4 o más: nombres = todas menos las últimas dos, apellidos = últimas dos

        Si en tu CSV agregas columnas `nombres` y `apellidos`, esas tendrán prioridad.
        """
        nombre_completo = VisorCSV.valor_limpio(nombre_completo)
        if not nombre_completo:
            return "", ""

        # Soporte para formato: "Apellidos, Nombres"
        if "," in nombre_completo:
            apellidos, nombres = [p.strip() for p in nombre_completo.split(",", 1)]
            return nombres, apellidos

        partes = nombre_completo.split()
        if len(partes) == 1:
            return partes[0], ""
        if len(partes) == 2:
            return partes[0], partes[1]
        if len(partes) == 3:
            return partes[0], " ".join(partes[1:])

        return " ".join(partes[:-2]), " ".join(partes[-2:])

    @staticmethod
    def normalizar_fecha(valor):
        """
        Devuelve fecha en formato YYYY-MM-DD o None.
        Acepta:
        - YYYY-MM-DD
        - DD/MM/YYYY
        - DD-MM-YYYY
        - YYYY/MM/DD
        - fecha con hora, por ejemplo 2026-05-04 14:30:00
        """
        valor = VisorCSV.valor_limpio(valor)
        if not valor:
            return None

        # Si viene con hora, dejar solo la fecha.
        valor = valor.split()[0]

        formatos = ["%Y-%m-%d", "%d/%m/%Y", "%d-%m-%Y", "%Y/%m/%d"]
        for fmt in formatos:
            try:
                return datetime.strptime(valor, fmt).date().isoformat()
            except ValueError:
                continue
        return None

    @staticmethod
    def normalizar_entero(valor):
        valor = VisorCSV.valor_limpio(valor)
        if not valor:
            return None
        try:
            return int(float(valor))
        except ValueError:
            return None

    def primer_valor(self, row, *campos):
        """
        Devuelve el primer campo no vacío de una fila CSV.
        Permite compatibilidad entre generadores antiguos y el generador V5 LMIC FULL.
        """
        for campo in campos:
            valor = self.valor_limpio(row.get(campo))
            if valor:
                return valor
        return ""

    def normalizar_fila_para_trabajador(self, row):
        """
        Toma una fila del CSV y la adapta a la tabla `trabajador`.

        Compatible con:
        - CSV antiguo: person, creation_date.
        - CSV V5 LMIC FULL: person_name, created_at, ug65_name, app_port, sketch_path.
        """
        id_dispositivo = self.normalizar_entero(
            self.primer_valor(row, "id_dispositivo", "node_id", "ug65_name", "name")
        )

        nombres_csv = self.valor_limpio(row.get("nombres"))
        apellidos_csv = self.valor_limpio(row.get("apellidos"))
        person = self.primer_valor(row, "person", "person_name", "trabajador", "description", "nombre")

        if nombres_csv or apellidos_csv:
            nombres = nombres_csv
            apellidos = apellidos_csv
        else:
            nombres, apellidos = self.parsear_nombre_completo(person)

        empresa = self.valor_limpio(row.get("empresa")) or self.valor_limpio(self.var_empresa_default.get()) or None
        proyecto = self.valor_limpio(row.get("proyecto")) or self.valor_limpio(self.var_proyecto_default.get()) or None

        creation_date = self.primer_valor(row, "creation_date", "created_at", "fecha_creacion")

        fecha_ingreso_raw = row.get("fecha_ingreso")
        if not self.valor_limpio(fecha_ingreso_raw) and USAR_CREATION_DATE_COMO_FECHA_INGRESO:
            fecha_ingreso_raw = creation_date

        fecha_ingreso = self.normalizar_fecha(fecha_ingreso_raw)
        fecha_nacimiento = self.normalizar_fecha(row.get("fecha_nacimiento"))

        return {
            "id_dispositivo": id_dispositivo,
            "nombres": nombres or None,
            "apellidos": apellidos or None,
            "empresa": empresa,
            "proyecto": proyecto,
            "fecha_ingreso": fecha_ingreso,
            "fecha_nacimiento": fecha_nacimiento,
            "fotografia": None,
            "fotografia_path": "",
            "fotografia_clear": False,
            "person": person,
            "devEUI": self.primer_valor(row, "devEUI", "deveui"),
            "appKey": self.primer_valor(row, "appKey", "appkey"),
            "band_mac": self.primer_valor(row, "band_mac", "mac_pulsera", "mac_banda"),
            "period_ms": self.primer_valor(row, "period_ms", "tx_interval_ms"),
            "creation_date": creation_date,
        }


    # =========================================================
    # PERSISTENCIA LOCAL Y RECUPERACIÓN DESDE MARIA DB
    # =========================================================
    def ruta_cache_local(self):
        """
        Archivo auxiliar que queda junto al CSV.
        Permite que los cambios hechos desde la interfaz no se pierdan al volver a abrir nodes.csv.
        """
        if not self.ruta_csv:
            return None
        ruta = Path(self.ruta_csv)
        return ruta.with_name(f"{ruta.stem}_trabajadores_guardado.json")

    def guardar_cache_local(self):
        """
        Guarda localmente los datos editados en la interfaz.
        No reemplaza MariaDB; solo sirve como respaldo para que al reabrir el CSV
        se mantengan cumpleaños, empresa, proyecto y fotos seleccionadas.
        """
        ruta_cache = self.ruta_cache_local()
        if ruta_cache is None or not self.filas_normalizadas:
            return False

        trabajadores = {}
        for fila in self.filas_normalizadas:
            id_dispositivo = fila.get("id_dispositivo")
            if id_dispositivo is None:
                continue

            foto_b64 = None
            if fila.get("fotografia"):
                try:
                    foto_b64 = base64.b64encode(fila["fotografia"]).decode("ascii")
                except Exception:
                    foto_b64 = None

            trabajadores[str(id_dispositivo)] = {
                "id_dispositivo": id_dispositivo,
                "nombres": fila.get("nombres"),
                "apellidos": fila.get("apellidos"),
                "empresa": fila.get("empresa"),
                "proyecto": fila.get("proyecto"),
                "fecha_ingreso": fila.get("fecha_ingreso"),
                "fecha_nacimiento": fila.get("fecha_nacimiento"),
                "fotografia_path": fila.get("fotografia_path") or "",
                "fotografia_clear": bool(fila.get("fotografia_clear")),
                "fotografia_b64": foto_b64,
            }

        data = {
            "version": 1,
            "csv": str(self.ruta_csv),
            "updated_at": datetime.now().isoformat(timespec="seconds"),
            "trabajadores": trabajadores,
        }

        try:
            with open(ruta_cache, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False, indent=2)
            return True
        except Exception as e:
            messagebox.showwarning("Advertencia", f"No se pudo guardar el respaldo local:\n{e}")
            return False

    def cargar_cache_local(self):
        ruta_cache = self.ruta_cache_local()
        if ruta_cache is None or not ruta_cache.exists() or not self.filas_normalizadas:
            return 0

        try:
            with open(ruta_cache, "r", encoding="utf-8") as f:
                data = json.load(f)
        except Exception:
            return 0

        trabajadores = data.get("trabajadores", {})
        recuperados = 0

        for fila in self.filas_normalizadas:
            id_dispositivo = fila.get("id_dispositivo")
            if id_dispositivo is None:
                continue

            guardado = trabajadores.get(str(id_dispositivo))
            if not guardado:
                continue

            for campo in (
                "nombres",
                "apellidos",
                "empresa",
                "proyecto",
                "fecha_ingreso",
                "fecha_nacimiento",
            ):
                if campo in guardado:
                    fila[campo] = guardado.get(campo) or None

            fila["fotografia_path"] = guardado.get("fotografia_path") or ""
            fila["fotografia_clear"] = bool(guardado.get("fotografia_clear"))

            foto_b64 = guardado.get("fotografia_b64")
            if foto_b64 and not fila["fotografia_clear"]:
                try:
                    fila["fotografia"] = base64.b64decode(foto_b64.encode("ascii"))
                except Exception:
                    fila["fotografia"] = None

            recuperados += 1

        return recuperados

    def enriquecer_filas_desde_mariadb(self, destino="actual", silencioso=True):
        """
        Si el trabajador ya existe en MariaDB, recupera sus datos.
        Esto permite que al volver a abrir nodes.csv se vean nuevamente cumpleaños,
        empresa, proyecto y fotografía guardada.
        """
        if not self.filas_normalizadas:
            return 0

        ids = [fila["id_dispositivo"] for fila in self.filas_normalizadas if fila.get("id_dispositivo") is not None]
        if not ids:
            return 0

        try:
            conn = self.conectar_mariadb(destino)
            placeholders = ",".join(["%s"] * len(ids))
            sql = f"""
                SELECT 
                    id_dispositivo,
                    nombres,
                    apellidos,
                    empresa,
                    proyecto,
                    fecha_ingreso,
                    fecha_nacimiento,
                    fotografia
                FROM trabajador
                WHERE id_dispositivo IN ({placeholders})
            """

            with conn.cursor() as cur:
                cur.execute(sql, ids)
                rows = cur.fetchall()
            conn.close()

        except Exception as e:
            if not silencioso:
                messagebox.showerror("Error al recuperar datos", f"No se pudo leer trabajadores desde MariaDB:\n{e}")
            return 0

        por_id = {self.normalizar_entero(row.get("id_dispositivo")): row for row in rows}
        recuperados = 0

        for fila in self.filas_normalizadas:
            row = por_id.get(fila.get("id_dispositivo"))
            if not row:
                continue

            for campo in ("nombres", "apellidos", "empresa", "proyecto"):
                valor = row.get(campo)
                if valor is not None and str(valor).strip() != "":
                    fila[campo] = valor

            for campo in ("fecha_ingreso", "fecha_nacimiento"):
                valor = row.get(campo)
                if valor:
                    fila[campo] = self.normalizar_fecha(valor)

            foto = row.get("fotografia")
            if foto:
                fila["fotografia"] = bytes(foto)
                fila["fotografia_path"] = f"Recuperada desde MariaDB {destino}"
                fila["fotografia_clear"] = False

            recuperados += 1

        return recuperados

