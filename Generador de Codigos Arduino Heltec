// ── Batería ──────────────────────────────────────────────────────────────────
uint16_t batteryInMV()
{
  analogReadResolution(12);
  analogReference(AR_INTERNAL_3_0);
  float mv_per_lsb = 3000.0F / 4096.0F;
  pinMode(PIN_BAT_ADC_CTL, OUTPUT);
  digitalWrite(PIN_BAT_ADC_CTL, 1);
  delay(10);
  int adcvalue = analogRead(PIN_BAT_ADC);
  digitalWrite(PIN_BAT_ADC_CTL, 0);
  uint16_t v = (uint16_t)((float)adcvalue * mv_per_lsb * 4.9f);
  debug_printf("battery volt : %d\r\n", v);
  return v;
}

// ── Utilidades internas ──────────────────────────────────────────────────────
static uint8_t normalizeBpm(uint8_t bpm)
{
  if (bpm == 0) return 60;
  if (bpm < 35) return 35;
  if (bpm > 220) return 220;
  return bpm;
}

static uint8_t extractBpmFromLine(const char* text)
{
  if (!text) return 0;

  uint16_t value = 0;
  bool found = false;

  for (const char* p = text; *p; ++p) {
    if (*p >= '0' && *p <= '9') {
      found = true;
      value = (uint16_t)(value * 10 + (*p - '0'));
      if (value > 255) return 255;
    } else if (found) {
      break;
    }
  }

  return found ? (uint8_t)value : 0;
}

static void resetMainUiState(bool eraseHeartArea)
{
  if (eraseHeartArea && heartVisible) {
    tft.fillRect(HEART_BOX_X, HEART_BOX_Y, HEART_BOX_W, HEART_BOX_H, CLR_BG);
  }

  mainUiDrawn      = false;
  heartVisible     = false;
  heartIsBig       = false;
  lastBpm          = 0;
  lastDisplayedBpm = 255;
  lastBeatTime     = 0;
  beatStartMs      = 0;
  lastHeartDrawMs  = 0;
}

// Borrado duro para transición desde pantallas temporales hacia la pantalla principal.
// La versión anterior limpiaba por zonas; eso dejaba pequeños espacios sin refrescar
// arriba del corazón y entre el panel BPM/corazón. Esta función barre toda la ST7789.
static void hardClearForMainScreen()
{
  tft.setTextWrap(false);
  tft.fillScreen(CLR_BG);

  // Segunda pasada por bandas. Es intencionalmente redundante: en la ST7789 ayuda
  // cuando viene de pantallas temporales con textos grandes o cambios rápidos.
  for (int16_t y = 0; y < SCREEN_H; y += 12) {
    tft.fillRect(0, y, SCREEN_W, 12, CLR_BG);
  }

  resetMainUiState(false);
}

void displayHardClear()
{
  displayStart();
  hardClearForMainScreen();
}

// Misma primitiva que el codigo Placaheltec.ino: dos circulos + triangulo.
static void drawHeart(int16_t x, int16_t y, int16_t r, uint16_t color)
{
  tft.fillCircle(x - r, y, r, color);
  tft.fillCircle(x + r, y, r, color);
  tft.fillTriangle(
    x - r * 2, y + r / 2,
    x + r * 2, y + r / 2,
    x,         y + (r * 5) / 2,
    color
  );
}

static void eraseHeart()
{
  tft.fillRect(HEART_BOX_X, HEART_BOX_Y, HEART_BOX_W, HEART_BOX_H, CLR_BG);
}

static void drawHeartFrame(bool big)
{
  eraseHeart();
  if (big) {
    drawHeart(HEART_CX, HEART_CY_BIG, HEART_R_BIG, CLR_RED);
  } else {
    drawHeart(HEART_CX, HEART_CY_SMALL, HEART_R_SMALL, CLR_RED_DIM);
  }

  heartVisible    = true;
  heartIsBig      = big;
  lastHeartDrawMs = millis();
}

static void drawHeartRestIfNeeded()
{
  if (!heartVisible) drawHeartFrame(false);
}

static void drawSeparator()
{
  tft.drawFastHLine(0, SEP_Y, 240, CLR_BLUE);
}

static void drawBpmNumber(uint8_t bpm)
{
  bpm = normalizeBpm(bpm);

  if (mainUiDrawn && lastDisplayedBpm == bpm) {
    drawSeparator();
    return;
  }

  // Solo borra el panel izquierdo. No toca el rectangulo del corazon.
  tft.fillRect(TOP_LEFT_X, TOP_LEFT_Y, TOP_LEFT_W, TOP_LEFT_H, CLR_BG);

  tft.setTextSize(6);
  tft.setTextColor(CLR_WHITE, CLR_BG);
  tft.setCursor(15, 15);

  // Mantiene estable la posicion cuando hay 2 digitos, igual que Placaheltec.ino.
  if (bpm < 100) tft.print(" ");
  tft.print(bpm);

  lastDisplayedBpm = bpm;
  drawSeparator();
}

static void drawTopStatus(const char* line, uint16_t color)
{
  tft.fillRect(TOP_LEFT_X, TOP_LEFT_Y, TOP_LEFT_W, TOP_LEFT_H, CLR_BG);
  tft.setTextSize(2);
  tft.setTextColor(color, CLR_BG);
  tft.setCursor(10, 25);
  tft.print(line && line[0] ? line : "Minerguard");

  lastDisplayedBpm = 0;
  drawSeparator();
}

static void drawBodyLines(const char* l2, const char* l3, uint16_t color)
{
  // Zona inferior completa. El corazon ya no vive aqui, por eso se puede limpiar.
  tft.fillRect(0, BODY_Y, 240, BODY_H, CLR_BG);

  tft.setTextWrap(false);
  tft.setTextSize(2);
  tft.setTextColor(color, CLR_BG);
  tft.setCursor(10, 75);
  tft.print(l2 && l2[0] ? l2 : "Escaneando...");

  tft.setTextSize(1);
  tft.setTextColor(CLR_YELLOW, CLR_BG);
  tft.setCursor(10, 118);
  tft.print(l3 && l3[0] ? l3 : "MINERGUARD");
}

// ── Encendido / apagado ──────────────────────────────────────────────────────
static void displayStart()
{
  if (isDisplayOn == 0) {
    isDisplayOn = 1;
    pinMode(PIN_TFT_VDD_CTL,  OUTPUT);
    pinMode(PIN_TFT_LEDA_CTL, OUTPUT);
    digitalWrite(PIN_TFT_VDD_CTL,  TFT_VDD_ENABLE);
    digitalWrite(PIN_TFT_LEDA_CTL, TFT_LEDA_ENABLE);
    tft.init(135, 240);
    tft.setRotation(3);
    tft.setSPISpeed(40000000);
    tft.fillScreen(CLR_BG);
    resetMainUiState(false);
  }
}

void displayEnd()
{
  if (isDisplayOn) {
    resetMainUiState(false);
    isDisplayOn = 0;
    SPI1.end();
    digitalWrite(PIN_TFT_CS,  0);
    digitalWrite(PIN_TFT_DC,  0);
    digitalWrite(PIN_TFT_RST, 0);
    digitalWrite(PIN_TFT_VDD_CTL,  !TFT_VDD_ENABLE);
    digitalWrite(PIN_TFT_LEDA_CTL, !TFT_LEDA_ENABLE);
  }
}

// ── tickHeartbeat: logica simple y robusta extraida del codigo que funcionaba ─
void tickHeartbeat(uint8_t bpm)
{
  if (!isDisplayOn) return;

  bpm = normalizeBpm(bpm);
  uint32_t now = millis();

  // Evita saturar SPI si por alguna razon llegan ticks demasiado seguidos.
  if (lastHeartDrawMs != 0 && (now - lastHeartDrawMs) < 18) return;

  uint32_t beatInterval = 60000UL / (uint32_t)bpm;

  // Si cambia el BPM, actualiza numero y reinicia un latido visible.
  if (!heartVisible || bpm != lastBpm || lastBeatTime == 0) {
    lastBpm      = bpm;
    lastBeatTime = now;
    beatStartMs  = now;
    drawBpmNumber(bpm);
    drawHeartFrame(true);
    return;
  }

  if ((now - lastBeatTime) >= beatInterval) {
    // Si el loop se demoro por LoRa/BLE, no queda pegado: salta al ciclo actual.
    uint32_t cycles = (now - lastBeatTime) / beatInterval;
    lastBeatTime += cycles * beatInterval;
    beatStartMs = now;
    drawHeartFrame(true);
    return;
  }

  // Igual que Placaheltec: contraccion breve y reposo rojo oscuro.
  if (heartIsBig && (now - beatStartMs >= 100)) {
    drawHeartFrame(false);
  }
}

void hideHeartbeat()
{
  if (heartVisible) eraseHeart();
  heartVisible    = false;
  heartIsBig      = false;
  lastBpm         = 0;
  lastBeatTime    = 0;
  beatStartMs     = 0;
  lastHeartDrawMs = 0;
}

// ── Pantalla principal ───────────────────────────────────────────────────────
void displayMainScreen(const char* l1, const char* l2, const char* l3,
                       uint16_t color, bool showHeart)
{
  displayStart();
  tft.setTextWrap(false);

  // Primera entrada a la pantalla principal después de MINERGUARD/JOINING/JOINED:
  // limpiar TODO antes de dibujar por zonas. Esto elimina la parte congelada
  // que podía quedar de la animación inicial.
  if (!mainUiDrawn) {
    hardClearForMainScreen();
  }

  if (showHeart) {
    uint8_t bpm = extractBpmFromLine(l1);
    if (bpm == 0) bpm = lastBpm ? lastBpm : 60;
    drawBpmNumber(bpm);
    drawHeartRestIfNeeded();
  } else {
    hideHeartbeat();
    drawTopStatus(l1, color);
  }

  drawBodyLines(l2, l3, color);
  mainUiDrawn = true;
}

