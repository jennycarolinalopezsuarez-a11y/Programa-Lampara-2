        "name": "Normalizar HELTEC UG65",
        "func": "// --- NORMALIZAR HELTEC UG65 / CHIRPSTACK ---\n// Acepta cualquier DevEUI válido (16 hex), sin depender de uno fijo\n\nvar p = msg.payload || {};\n\n// Si payload viene como string, intentar parsearlo\nif (typeof p === \"string\") {\n    try {\n        p = JSON.parse(p);\n    } catch (e) {\n        p = {};\n    }\n}\n\n// ----------------------------------------------------\n// Función: extraer y normalizar DevEUI desde varios campos\n// ----------------------------------------------------\nfunction getNormalizedDevEUI(obj) {\n    var candidates = [\n        obj.devEUI,\n        obj.devEui,\n        obj.deviceInfo && obj.deviceInfo.devEUI,\n        obj.deviceInfo && obj.deviceInfo.devEui,\n        obj.endDeviceIds && obj.endDeviceIds.devEui,\n        obj.endDeviceIds && obj.endDeviceIds.devEUI\n    ];\n\n    for (var i = 0; i < candidates.length; i++) {\n        var v = candidates[i];\n        if (v !== undefined && v !== null && v !== \"\") {\n            var clean = String(v)\n                .replace(/[^0-9a-fA-F]/g, \"\")   // elimina :, -, espacios, etc.\n                .toUpperCase();\n\n            if (/^[0-9A-F]{16}$/.test(clean)) {\n                return clean;\n            }\n        }\n    }\n    return null;\n}\n\n// ----------------------------------------------------\n// Función: extraer nombre del dispositivo\n// ----------------------------------------------------\nfunction getDeviceName(obj) {\n    return obj.deviceName ||\n           (obj.deviceInfo && obj.deviceInfo.deviceName) ||\n           (obj.deviceInfo && obj.deviceInfo.name) ||\n           null;\n}\n\n// ----------------------------------------------------\n// Función: extraer nombre de aplicación\n// ----------------------------------------------------\nfunction getApplicationName(obj) {\n    return obj.applicationName ||\n           (obj.deviceInfo && obj.deviceInfo.applicationName) ||\n           null;\n}\n\n// ----------------------------------------------------\n// Información del gateway / radio\n// ----------------------------------------------------\nvar rx0 = {};\nif (p.rxInfo && Array.isArray(p.rxInfo) && p.rxInfo.length > 0) {\n    rx0 = p.rxInfo[0];\n}\n\nvar tx = p.txInfo || {};\nvar dr = tx.dataRate || {};\n\n// ----------------------------------------------------\n// Normalizar DevEUI\n// ----------------------------------------------------\nvar normalizedDevEUI = getNormalizedDevEUI(p);\n\n// ----------------------------------------------------\n// Crear objeto limpio de salida\n// ----------------------------------------------------\nvar out = {\n    timestamp: p.time || p.gatewayTime || new Date().toISOString(),\n    application: getApplicationName(p),\n    application_id: p.applicationID || p.applicationId || null,\n    device_name: getDeviceName(p),\n    dev_eui: normalizedDevEUI,\n    dev_eui_valid: normalizedDevEUI !== null,\n\n    fcnt: (typeof p.fCnt !== \"undefined\") ? p.fCnt :\n          (typeof p.fCntUp !== \"undefined\") ? p.fCntUp : null,\n\n    fport: (typeof p.fPort !== \"undefined\") ? p.fPort : null,\n\n    gateway_id: rx0.mac || rx0.gatewayId || null,\n    gateway_name: rx0.name || rx0.gatewayName || null,\n    rssi: (typeof rx0.rssi !== \"undefined\") ? rx0.rssi : null,\n    snr: (typeof rx0.loRaSNR !== \"undefined\") ? rx0.loRaSNR :\n         (typeof rx0.snr !== \"undefined\") ? rx0.snr : null,\n\n    frequency: tx.frequency || null,\n    sf: dr.spreadFactor || null,\n    bandwidth: dr.bandwidth || null,\n\n    raw_data_hex: null,\n    source: \"UG65_Heltec_Only\"\n};\n\n// ----------------------------------------------------\n// Convertir payload LoRa Base64 -> HEX\n// ----------------------------------------------------\nif (p.data) {\n    try {\n        out.raw_data_hex = Buffer.from(p.data, \"base64\").toString(\"hex\").toUpperCase();\n    } catch (e2) {\n        out.raw_data_hex = null;\n    }\n}\n\n// ----------------------------------------------------\n// Si quieres rechazar mensajes sin DevEUI válido, activa esto\n// ----------------------------------------------------\n// if (!out.dev_eui_valid) {\n//     node.warn(\"Mensaje descartado: DevEUI inválido o ausente\");\n//     return null;\n// }\n\n// ----------------------------------------------------\n// Salida\n// ----------------------------------------------------\nmsg.payload = out;\nmsg.topic = \"minerguard/up/\" + (out.dev_eui || \"unknown\");\n\nreturn msg;",
