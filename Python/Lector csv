    def nombre_destino(self, destino="actual"):
        if destino == "actual":
            return "servidor actual"
        if destino == "nuevo_100":
            return "nuevo server 192.168.100.105"
        if destino == "nuevo_60":
            return "nuevo server 192.168.60.200"
        if destino == "nuevo":
            return f"nuevo server seleccionado {self.valor_limpio(self.var_host_nuevo_server.get())}"
        return str(destino)

    def obtener_config_mariadb(self, destino="actual"):
        """
        destino:
        - "actual": usa DB_CONFIG, actualmente 192.168.60.197.
        - "nuevo": usa la IP seleccionada en la interfaz.
        - "nuevo_100": usa 192.168.100.105.
        - "nuevo_60": usa 192.168.60.200.
        """
        if destino == "actual":
            config = dict(DB_CONFIG)
        elif destino == "nuevo_100":
            config = dict(DB_CONFIG_NUEVO_SERVER_100)
        elif destino == "nuevo_60":
            config = dict(DB_CONFIG_NUEVO_SERVER_60)
        elif destino == "nuevo":
            config = dict(DB_CONFIG_NUEVO_SERVER)
            host_nuevo = self.valor_limpio(self.var_host_nuevo_server.get())
            if not host_nuevo or "XXX" in host_nuevo:
                raise RuntimeError("Debes escribir o seleccionar la IP real del nuevo servidor MariaDB.")
            config["host"] = host_nuevo
        else:
            raise RuntimeError(f"Destino MariaDB no reconocido: {destino}")

        config["cursorclass"] = pymysql.cursors.DictCursor
        return config

    def conectar_mariadb(self, destino="actual"):
        if pymysql is None:
            raise RuntimeError("Falta instalar pymysql. Ejecuta: pip install pymysql")

        config = self.obtener_config_mariadb(destino)
        return pymysql.connect(**config)

    def probar_conexion(self, destino="actual"):
        try:
            config = self.obtener_config_mariadb(destino)
            conn = pymysql.connect(**config)
            with conn.cursor() as cur:
                cur.execute("SELECT DATABASE() AS db_actual, VERSION() AS version, @@hostname AS host_mariadb")
                row = cur.fetchone()
            conn.close()

            nombre_destino = self.nombre_destino(destino)
            messagebox.showinfo(
                "Conexión correcta",
                f"Conectado al {nombre_destino}.\n"
                f"IP configurada: {config['host']}\n"
                f"Base de datos: {row['db_actual']}\n"
                f"Host MariaDB: {row['host_mariadb']}\n"
                f"Versión: {row['version']}",
            )
        except Exception as e:
            nombre_destino = self.nombre_destino(destino)
            messagebox.showerror(
                "Error de conexión",
                f"No se pudo conectar al {nombre_destino}:\n{e}",
            )

    def probar_conexion_nuevos_servidores(self):
        resultados = []
        for destino in ("nuevo_100", "nuevo_60"):
            try:
                config = self.obtener_config_mariadb(destino)
                conn = pymysql.connect(**config)
                with conn.cursor() as cur:
                    cur.execute("SELECT DATABASE() AS db_actual, VERSION() AS version, @@hostname AS host_mariadb")
