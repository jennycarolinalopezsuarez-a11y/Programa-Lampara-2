    def asegurar_tabla_trabajador(self, cur):
        """
        Crea la tabla trabajador si no existe y agrega columnas mínimas si faltan.
        Esto ayuda cuando el nuevo servidor está recién instalado.
        """
        cur.execute("""
        CREATE TABLE IF NOT EXISTS trabajador (
            id_dispositivo INT NOT NULL,
            nombres VARCHAR(120) NULL,
            apellidos VARCHAR(120) NULL,
            empresa VARCHAR(120) NULL,
            proyecto VARCHAR(120) NULL,
            fecha_ingreso DATE NULL,
            fecha_nacimiento DATE NULL,
            fotografia LONGBLOB NULL,
            fecha_actualizacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            PRIMARY KEY (id_dispositivo)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
        """)

        cur.execute("SHOW COLUMNS FROM trabajador")
        rows = cur.fetchall()
        existentes = set()
        for row in rows:
            if isinstance(row, dict):
                existentes.add(row.get("Field"))
            else:
                existentes.add(row[0])

        columnas_requeridas = {
            "id_dispositivo": "INT NOT NULL",
            "nombres": "VARCHAR(120) NULL",
            "apellidos": "VARCHAR(120) NULL",
            "empresa": "VARCHAR(120) NULL",
            "proyecto": "VARCHAR(120) NULL",
            "fecha_ingreso": "DATE NULL",
            "fecha_nacimiento": "DATE NULL",
            "fotografia": "LONGBLOB NULL",
            "fecha_actualizacion": "TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
        }

        for columna, definicion in columnas_requeridas.items():
            if columna not in existentes:
                try:
                    cur.execute(f"ALTER TABLE trabajador ADD COLUMN {columna} {definicion}")
                except Exception:
                    pass

        try:
            cur.execute("SHOW INDEX FROM trabajador WHERE Column_name = 'id_dispositivo'")
            indexes = cur.fetchall()
            tiene_unico = False
            for idx in indexes:
                non_unique = idx.get("Non_unique") if isinstance(idx, dict) else idx[1]
                if int(non_unique) == 0:
                    tiene_unico = True
                    break
            if not tiene_unico:
                cur.execute("ALTER TABLE trabajador ADD UNIQUE KEY uk_trabajador_id_dispositivo (id_dispositivo)")
        except Exception:
            pass

    def guardar_todo_en_mariadb(self, destino="actual", mostrar_mensaje=True):
        if not self.filas_normalizadas:
            messagebox.showwarning("Atención", "Primero debes cargar un archivo CSV válido.")
            return False, "No hay filas cargadas."

        sql = """
        INSERT INTO trabajador
            (id_dispositivo, nombres, apellidos, empresa, proyecto, fecha_ingreso, fecha_nacimiento, fotografia)
        VALUES
            (%s, %s, %s, %s, %s, %s, %s, %s)
        ON DUPLICATE KEY UPDATE
            nombres = VALUES(nombres),
            apellidos = VALUES(apellidos),
            empresa = VALUES(empresa),
            proyecto = VALUES(proyecto),
            fecha_ingreso = VALUES(fecha_ingreso),
            fecha_nacimiento = VALUES(fecha_nacimiento),
            fotografia = CASE
                WHEN %s = 1 THEN NULL
                WHEN VALUES(fotografia) IS NOT NULL THEN VALUES(fotografia)
                ELSE fotografia
            END
        """

        conn = None
        try:
            config = self.obtener_config_mariadb(destino)
            conn = pymysql.connect(**config)

            insertados_o_actualizados = 0
            omitidos = 0
            fotos_cargadas = 0
            fotos_quitadas = 0

            with conn.cursor() as cur:
                self.asegurar_tabla_trabajador(cur)

                for fila in self.filas_normalizadas:
                    if fila["id_dispositivo"] is None:
                        omitidos += 1
                        continue

                    fotografia_bytes = fila.get("fotografia")
                    quitar_foto = 1 if fila.get("fotografia_clear") else 0

                    if fotografia_bytes:
                        fotos_cargadas += 1
                    if quitar_foto:
                        fotos_quitadas += 1

                    cur.execute(
                        sql,
                        (
                            fila["id_dispositivo"],
                            fila["nombres"],
                            fila["apellidos"],
                            fila["empresa"],
                            fila["proyecto"],
                            fila["fecha_ingreso"],
                            fila["fecha_nacimiento"],
                            fotografia_bytes,
                            quitar_foto,
                        ),
                    )
                    insertados_o_actualizados += 1

            conn.commit()
            conn.close()

            # También guarda respaldo local para que al reabrir el CSV no se pierdan los cambios.
            self.guardar_cache_local()

            nombre_destino = self.nombre_destino(destino)
            mensaje = (
                f"✅ Tabla trabajador actualizada en {nombre_destino} ({config['host']}): "
                f"{insertados_o_actualizados} registros insertados/actualizados."
            )
            if fotos_cargadas:
                mensaje += f"\n📷 Fotografías cargadas/actualizadas: {fotos_cargadas}."
            if fotos_quitadas:
                mensaje += f"\n🗑️ Fotografías marcadas para quitar: {fotos_quitadas}."
            if omitidos:
                mensaje += f"\n⚠️ Omitidos: {omitidos} registros sin id_dispositivo."

            self.lbl_status.config(text=mensaje.replace("\n", " | "))
            if mostrar_mensaje:
                messagebox.showinfo("Proceso completado", mensaje)
            return True, mensaje

        except Exception as e:
            try:
                if conn:
                    conn.rollback()
                    conn.close()
            except Exception:
                pass

            nombre_destino = self.nombre_destino(destino)
            mensaje = f"❌ No se pudo actualizar la tabla trabajador en {nombre_destino}:\n{e}"

            if mostrar_mensaje:
                messagebox.showerror("Error al guardar", mensaje)
            return False, mensaje

    def guardar_todo_en_ambos_servidores(self):
        """
        Compatibilidad: guarda en servidor actual + nuevo seleccionado.
        """
        if not self.filas_normalizadas:
            messagebox.showwarning("Atención", "Primero debes cargar un archivo CSV válido.")
            return

        ok_actual, msg_actual = self.guardar_todo_en_mariadb("actual", mostrar_mensaje=False)
        ok_nuevo, msg_nuevo = self.guardar_todo_en_mariadb("nuevo", mostrar_mensaje=False)

        mensaje = "Resultado de guardado en servidor actual + nuevo seleccionado:\n\n"
        mensaje += f"{msg_actual}\n\n{msg_nuevo}"

        self.lbl_status.config(text=mensaje.replace("\n", " | "))
        if ok_actual and ok_nuevo:
            messagebox.showinfo("Proceso completado", mensaje)
        else:
            messagebox.showwarning("Proceso con observaciones", mensaje)

    def guardar_todo_en_nuevos_servidores(self):
        """
        Guarda en las dos IP del nuevo servidor:
        - 192.168.100.105
        - 192.168.60.200
        """
        if not self.filas_normalizadas:
            messagebox.showwarning("Atención", "Primero debes cargar un archivo CSV válido.")
            return

        ok_100, msg_100 = self.guardar_todo_en_mariadb("nuevo_100", mostrar_mensaje=False)
        ok_60, msg_60 = self.guardar_todo_en_mariadb("nuevo_60", mostrar_mensaje=False)

        mensaje = "Resultado de guardado en ambos nuevos servidores:\n\n"
        mensaje += f"{msg_100}\n\n{msg_60}"

        self.lbl_status.config(text=mensaje.replace("\n", " | "))
        if ok_100 and ok_60:
            messagebox.showinfo("Proceso completado", mensaje)
        else:
            messagebox.showwarning("Proceso con observaciones", mensaje)

    def guardar_todo_en_todos_los_servidores(self):
        """
        Guarda en servidor actual y en las dos IP del nuevo servidor.
        """
        if not self.filas_normalizadas:
            messagebox.showwarning("Atención", "Primero debes cargar un archivo CSV válido.")
            return

        resultados = [
            self.guardar_todo_en_mariadb("actual", mostrar_mensaje=False),
            self.guardar_todo_en_mariadb("nuevo_100", mostrar_mensaje=False),
            self.guardar_todo_en_mariadb("nuevo_60", mostrar_mensaje=False),
        ]

        mensaje = "Resultado de guardado en todos los servidores:\n\n"
        mensaje += "\n\n".join(msg for _ok, msg in resultados)

        self.lbl_status.config(text=mensaje.replace("\n", " | "))
        if all(ok for ok, _msg in resultados):
            messagebox.showinfo("Proceso completado", mensaje)
        else:
            messagebox.showwarning("Proceso con observaciones", mensaje)


