    def get_csv_path(self) -> Path:
        base = Path(self.output_dir.get().strip() or Path.cwd())
        return base / "nodes.csv"

    def read_existing_credentials(self, csv_path: Path) -> tuple[set[str], set[str]]:
        """Lee nodes.csv y retorna DevEUI/AppKey ya usados para evitar duplicados."""
        used_dev_euis: set[str] = set()
        used_app_keys: set[str] = set()

        if not csv_path.exists():
            return used_dev_euis, used_app_keys

        try:
            with csv_path.open("r", newline="", encoding="utf-8") as f:
                reader = csv.DictReader(f)
                for row in reader:
                    dev = sanitize_hex(row.get("devEUI", ""))
                    key = sanitize_hex(row.get("appKey", ""))
                    if len(dev) == 16:
                        used_dev_euis.add(dev)
                    if len(key) == 32:
                        used_app_keys.add(key)
        except Exception as e:
            self.write_log(f"Advertencia: no se pudo leer nodes.csv para validar unicidad: {e}")

        return used_dev_euis, used_app_keys

    def ensure_unique_otaa_credentials(self, csv_path: Path) -> tuple[str, str]:
        """Genera DevEUI y AppKey nuevos y únicos contra nodes.csv."""
        used_dev_euis, used_app_keys = self.read_existing_credentials(csv_path)

        dev_eui = random_unique_hex(8, used_dev_euis)
        app_key = random_unique_hex(16, used_app_keys)

        self.dev_eui.set(dev_eui)
        self.app_key.set(app_key)

        if not self.app_eui.get().strip():
            self.app_eui.set("0000000000000000")

        self.write_log(f"Credenciales únicas generadas -> DevEUI: {dev_eui} / AppKey: {app_key}")
        return dev_eui, app_key

    def regen_deveui(self):
        used_dev_euis, _ = self.read_existing_credentials(self.get_csv_path())
        nuevo_dev_eui = random_unique_hex(8, used_dev_euis)
        self.dev_eui.set(nuevo_dev_eui)
        self.write_log(f"Nuevo DevEUI único: {self.dev_eui.get()}")

    def regen_appkey(self):
        _, used_app_keys = self.read_existing_credentials(self.get_csv_path())
        self.app_key.set(random_unique_hex(16, used_app_keys))
        self.write_log("AppKey única regenerada.")

    def choose_folder(self):
        folder = filedialog.askdirectory(initialdir=self.output_dir.get() or str(Path.cwd()))
        if folder:
            self.output_dir.set(folder)
            self.write_log(f"Carpeta seleccionada: {folder}")
