    def cargar_csv(self):
        filepath = filedialog.askopenfilename(
            title="Seleccionar inventario (nodes.csv)",
            initialdir=r"C:\Users\Innovacion FMT\Documents\Tomas\Minerguard\Prueba Codigos Generador",
            filetypes=[("Archivos CSV", "*.csv"), ("Todos los archivos", "*.*")],
        )

        if not filepath:
            return

        self.tree.delete(*self.tree.get_children())
        self.filas_normalizadas.clear()
        self.ruta_csv = filepath

        try:
            # utf-8-sig evita problemas si el CSV viene con BOM desde Excel.
            with open(filepath, "r", encoding="utf-8-sig", newline="") as f:
                reader = csv.DictReader(f)
                contador = 0
                omitidos = 0

                for row in reader:
                    fila = self.normalizar_fila_para_trabajador(row)

                    if fila["id_dispositivo"] is None:
                        omitidos += 1
                        continue

                    self.filas_normalizadas.append(fila)
                    contador += 1

            # 1) Recupera datos ya guardados en MariaDB actual.
            recuperados_bd_actual = self.enriquecer_filas_desde_mariadb("actual", silencioso=True)

            # 2) Recupera desde las dos IP del nuevo servidor.
            recuperados_bd_nuevo = 0
            host_original = self.valor_limpio(self.var_host_nuevo_server.get())
            for host_nuevo in NUEVO_SERVER_IPS:
                if host_nuevo and host_nuevo != DB_CONFIG["host"]:
                    self.var_host_nuevo_server.set(host_nuevo)
                    recuperados_bd_nuevo += self.enriquecer_filas_desde_mariadb("nuevo", silencioso=True)
            if host_original:
                self.var_host_nuevo_server.set(host_original)

            # 3) Recupera los cambios locales guardados junto al CSV.
            #    Esto evita perder cumpleaños, empresa, proyecto y fotos si se vuelve a abrir el CSV.
            recuperados_cache = self.cargar_cache_local()

            for i, fila in enumerate(self.filas_normalizadas):
                self.insertar_o_actualizar_fila_tree(i, fila)

            nombre_archivo = Path(filepath).name
            mensaje = f"✅ Se cargaron {contador} trabajadores desde '{nombre_archivo}'"
            if recuperados_bd_actual:
                mensaje += f" | 🔁 Recuperados desde MariaDB actual: {recuperados_bd_actual}"
            if recuperados_bd_nuevo:
                mensaje += f" | 🔁 Recuperados desde MariaDB nuevo: {recuperados_bd_nuevo}"
            if recuperados_cache:
                mensaje += f" | 💾 Recuperados desde guardado local: {recuperados_cache}"
            if omitidos:
                mensaje += f" | ⚠️ Omitidos por falta de node_id/id_dispositivo: {omitidos}"
            self.lbl_status.config(text=mensaje)

        except Exception as e:
            messagebox.showerror("Error de lectura", f"No se pudo leer el archivo CSV:\n{e}")


    def insertar_o_actualizar_fila_tree(self, indice, fila):
        valores = (
            fila["id_dispositivo"],
            fila["person"],
            fila["nombres"] or "",
            fila["apellidos"] or "",
            fila["empresa"] or "",
            fila["proyecto"] or "",
            fila["fecha_ingreso"] or "",
            fila["fecha_nacimiento"] or "",
            self.estado_foto_texto(fila),
            fila["devEUI"],
            fila["appKey"],
            fila["band_mac"],
            fila["period_ms"],
            fila["creation_date"],
        )

        iid = str(indice)
        if self.tree.exists(iid):
            self.tree.item(iid, values=valores)
        else:
            self.tree.insert("", "end", iid=iid, values=valores)

    @staticmethod
    def estado_foto_texto(fila):
        if fila.get("fotografia_clear"):
            return "Quitar"
        if fila.get("fotografia"):
            return "Sí"
        return "No"

    def obtener_indice_seleccionado(self):
        seleccion = self.tree.selection()
        if not seleccion:
            return None
        try:
            return int(seleccion[0])
        except ValueError:
            return None

    def aplicar_valores_default_a_filas_vacias(self):
        if not self.filas_normalizadas:
            messagebox.showwarning("Atención", "Primero debes cargar un archivo CSV válido.")
            return

        empresa_default = self.valor_limpio(self.var_empresa_default.get()) or None
        proyecto_default = self.valor_limpio(self.var_proyecto_default.get()) or None
        cambios = 0

        for i, fila in enumerate(self.filas_normalizadas):
            cambio_fila = False
            if not fila.get("empresa"):
                fila["empresa"] = empresa_default
                cambio_fila = True
            if not fila.get("proyecto"):
                fila["proyecto"] = proyecto_default
                cambio_fila = True
            if cambio_fila:
                cambios += 1
                self.insertar_o_actualizar_fila_tree(i, fila)

        self.guardar_cache_local()
        self.lbl_status.config(text=f"✅ Valores por defecto aplicados a {cambios} fila(s) vacía(s).")

