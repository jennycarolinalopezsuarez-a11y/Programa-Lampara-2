   ========================================================= */
void setup() {
  boardInit(LORA_DEBUG_ENABLE, LORA_DEBUG_SERIAL_NUM, 115200);
  displayInit();
  // Al salir de la pantalla inicial, hacemos un barrido completo antes
  // de que la UI principal empiece a dibujar por zonas.
  displayHardClear();

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(BUTTON_PIN), buttonWakeUpISR, CHANGE);

  Bluefruit.begin(0, 1);
  Bluefruit.setName(NODE_LABEL);

  svcHR.begin(); chrHR.begin();
  svcBAT.begin(); chrBAT.begin();

  Bluefruit.Central.setConnectCallback(connect_cb);
  Bluefruit.Central.setDisconnectCallback(disconnect_cb);
  Bluefruit.Scanner.setRxCallback(scan_cb);
  Bluefruit.Scanner.filterRssi(-95);
  Bluefruit.Scanner.setInterval(160, 160); 
  
  Bluefruit.Scanner.useActiveScan(false);
  Bluefruit.Scanner.start(0);

  
  deviceState = DEVICE_STATE_INIT;
}

/* =========================================================
   LOOP PRINCIPAL
   ========================================================= */
void loop() {
  uint32_t now = millis();

  if (now - lastScanKick > 1500) {
    lastScanKick = now;
    if (!Bluefruit.Scanner.isRunning()) Bluefruit.Scanner.start(0);
  }

  // 1. Revisa el botón de pánico
  handlePanicButton();

  // 2. Redibuja texto si hubo cambio de estado.
  //    displayMainScreen() no reinicia el latido ni borra el rectangulo del corazon.
  if (screenNeedsUpdate) {
    screen_text(scrLine1, scrLine2, scrLine3, scrColor);
    screenNeedsUpdate = false;
  }

  // 3. Animacion del corazon estilo codigo original:
  //    se ejecuta desde loop(), sin SoftwareTimer externo, para no competir
  //    con BLE/LoRa ni tocar SPI desde otro contexto.
  static uint32_t lastHeartUiTick = 0;
  static bool heartWasVisible = false;
  if (bleConnected && hrValid && !panicActive) {
    if ((uint32_t)(now - lastHeartUiTick) >= 25) {
      lastHeartUiTick = now;
      tickHeartbeat(hrBpm);
      heartWasVisible = true;
    }
  } else if (heartWasVisible) {
    hideHeartbeat();
    heartWasVisible = false;
    lastHeartUiTick = now;
  }

  // 4. Gestiona tiempos de Beacons y envíos
  uint32_t tiempoTrascurrido = now - lastPeriodicSend;

  if (tiempoTrascurrido >= 15000 && !snapshotATaken) {
    cleanupOldBeacons();
    sortTopBeacons();
    memcpy(snapshotA, topBeacons, sizeof(topBeacons));
    snapshotATaken = true;
  }

  if (tiempoTrascurrido >= TX_INTERVAL_MS) {
    isTxConfirmed = false;
    requestImmediateTx = true;
  }

  // 5. Dispara LoRa si corresponde
  if (requestImmediateTx && deviceState != DEVICE_STATE_JOIN) {
    requestImmediateTx = false;
    deviceState = DEVICE_STATE_SEND;
  }

  switch (deviceState) {
    case DEVICE_STATE_INIT:
      LoRaWAN.init(loraWanClass, loraWanRegion);
      LoRaWAN.setDefaultDR(3);
      deviceState = DEVICE_STATE_JOIN;
      break;

    case DEVICE_STATE_JOIN:
      LoRaWAN.join();
      break;
      
    case DEVICE_STATE_SEND:
      prepareTxFrame(appPort);
      LoRaWAN.send();

      // Después del envío se pide refresco de pantalla. El payload no se modifica:
      // prepareTxFrame() ya cargó appData/appDataSize antes de LoRaWAN.send().
      screenNeedsUpdate = true;

      deviceState = DEVICE_STATE_CYCLE;
      break;
      
    case DEVICE_STATE_CYCLE:
      txDutyCycleTime = 100;
      LoRaWAN.cycle(txDutyCycleTime);
      deviceState = DEVICE_STATE_SLEEP;
      break;
      
    case DEVICE_STATE_SLEEP:
      LoRaWAN.sleep(loraWanClass);
      // Al volver desde LoRaWAN.sleep(), el loop retoma la pantalla y el corazon.
      if (deviceState == DEVICE_STATE_SEND) {
        if (!requestImmediateTx && (millis() - lastPeriodicSend) < TX_INTERVAL_MS) {
          deviceState = DEVICE_STATE_CYCLE;
        }
      }
      break;

    default:
      deviceState = DEVICE_STATE_INIT;
      break;
  }
}
