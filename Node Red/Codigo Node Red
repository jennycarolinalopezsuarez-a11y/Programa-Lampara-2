    {
        "id": "b06b4ab4cdf4d2f2",
        "type": "function",
        "z": "9220fbd1493c7969",
        "name": "Preparar_SQL_MariaDB",
        "func": "// =======================================================\n// PREPARAR SQL MARIADB DESDE HR1...HR20\n// Base: minerguard\n//\n// Salida 1:\n//   historico_dispositivos\n//   HR1 a HR10\n//\n// Salida 2:\n//   estado_actual_dispositivos\n//   HR11 a HR20, usando HR1 como id_dispositivo\n// =======================================================\n\n\n// =======================================================\n// 1. LEER MAPA HR\n// =======================================================\n\nlet hr = msg.modbus_mapping || null;\n\n// Respaldo: si no existe msg.modbus_mapping,\n// reconstruir desde msg.payload SOLO si tiene 20 valores.\nif (!hr && Array.isArray(msg.payload) && msg.payload.length >= 20) {\n    hr = {\n        hr1:  msg.payload[0],\n        hr2:  msg.payload[1],\n        hr3:  msg.payload[2],\n        hr4:  msg.payload[3],\n        hr5:  msg.payload[4],\n        hr6:  msg.payload[5],\n        hr7:  msg.payload[6],\n        hr8:  msg.payload[7],\n        hr9:  msg.payload[8],\n        hr10: msg.payload[9],\n        hr11: msg.payload[10],\n        hr12: msg.payload[11],\n        hr13: msg.payload[12],\n        hr14: msg.payload[13],\n        hr15: msg.payload[14],\n        hr16: msg.payload[15],\n        hr17: msg.payload[16],\n        hr18: msg.payload[17],\n        hr19: msg.payload[18],\n        hr20: msg.payload[19]\n    };\n}\n\nif (!hr) {\n    node.warn(\"Payload recibido:\");\n    node.warn(msg.payload);\n    node.error(\"No existe msg.modbus_mapping ni msg.payload con 20 valores HR. No se guarda en SQL.\", msg);\n    return null;\n}\n\n\n// =======================================================\n// 2. FUNCIONES AUXILIARES\n// =======================================================\n\nfunction numero(valor, defecto = null) {\n    if (valor === undefined || valor === null || valor === \"\") {\n        return defecto;\n    }\n\n    let n = Number(valor);\n    return isNaN(n) ? defecto : n;\n}\n\n\n// =======================================================\n// 3. VALIDAR ID DISPOSITIVO\n// =======================================================\n\nlet id_dispositivo = numero(hr.hr1, null);\n\nif (!id_dispositivo) {\n    node.warn(\"Mapa HR recibido:\");\n    node.warn(hr);\n    node.error(\"hr1 / id_dispositivo no es válido. No se puede guardar en SQL.\", msg);\n    return null;\n}\n\n\n// =======================================================\n// 4. SALIDA 1: HISTÓRICO\n// HR1 A HR10\n// =======================================================\n//\n// HR1  → id_dispositivo\n// HR2  → heart_rate\n// HR3  → panico\n// HR4  → posicion_actual\n// HR5  → posicion_anterior\n// HR6  → posicion_futura\n// HR7  → latitud\n// HR8  → longitud\n// HR9  → bateria_tag\n// HR10 → mayor\n// =======================================================\n\nlet msgHistorico = {};\n\nmsgHistorico.topic = `\nINSERT INTO historico_dispositivos (\n    id_dispositivo,\n    heart_rate,\n    panico,\n    posicion_actual,\n    posicion_anterior,\n    posicion_futura,\n    latitud,\n    longitud,\n    bateria_tag,\n    mayor\n) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n`;\n\nmsgHistorico.payload = [\n    id_dispositivo,          // HR1\n    numero(hr.hr2, null),    // HR2  heart_rate\n    numero(hr.hr3, 0),       // HR3  panico\n    numero(hr.hr4, null),    // HR4  posicion_actual\n    numero(hr.hr5, null),    // HR5  posicion_anterior\n    numero(hr.hr6, null),    // HR6  posicion_futura\n    numero(hr.hr7, null),    // HR7  latitud\n    numero(hr.hr8, null),    // HR8  longitud\n    numero(hr.hr9, null),    // HR9  bateria_tag\n    numero(hr.hr10, null)    // HR10 mayor\n];\n\nmsgHistorico.tipo_sql = \"historico_dispositivos\";\nmsgHistorico.hr_original = hr;\nmsgHistorico.mqtt_topic = msg.topic;\n\n\n// =======================================================\n// 5. SALIDA 2: ESTADO ACTUAL\n// HR11 A HR20\n// =======================================================\n//\n// HR1  → id_dispositivo\n// HR11 → banda_conectada\n// HR12 → bateria_banda\n// HR13 → rssi_lorawan\n// HR14 → snr_x10\n// HR15 → fcnt\n// HR16 → flags\n// HR17 → bc1_rssi\n// HR18 → bc2_rssi\n// HR19 → bc3_rssi\n// HR20 → valor_cero\n// =======================================================\n\nlet msgEstado = {};\n\nmsgEstado.topic = `\nINSERT INTO estado_actual_dispositivos (\n    id_dispositivo,\n    banda_conectada,\n    bateria_banda,\n    rssi_lorawan,\n    snr_x10,\n    fcnt,\n    flags,\n    bc1_rssi,\n    bc2_rssi,\n    bc3_rssi,\n    valor_cero\n) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\nON DUPLICATE KEY UPDATE\n    banda_conectada = VALUES(banda_conectada),\n    bateria_banda = VALUES(bateria_banda),\n    rssi_lorawan = VALUES(rssi_lorawan),\n    snr_x10 = VALUES(snr_x10),\n    fcnt = VALUES(fcnt),\n    flags = VALUES(flags),\n    bc1_rssi = VALUES(bc1_rssi),\n    bc2_rssi = VALUES(bc2_rssi),\n    bc3_rssi = VALUES(bc3_rssi),\n    valor_cero = VALUES(valor_cero),\n    fecha_actualizacion = CURRENT_TIMESTAMP\n`;\n\nmsgEstado.payload = [\n    id_dispositivo,          // HR1\n    numero(hr.hr11, 0),      // HR11 banda_conectada\n    numero(hr.hr12, null),   // HR12 bateria_banda\n    numero(hr.hr13, null),   // HR13 rssi_lorawan\n    numero(hr.hr14, null),   // HR14 snr_x10\n    numero(hr.hr15, null),   // HR15 fcnt\n    numero(hr.hr16, null),   // HR16 flags\n    numero(hr.hr17, null),   // HR17 bc1_rssi\n    numero(hr.hr18, null),   // HR18 bc2_rssi\n    numero(hr.hr19, null),   // HR19 bc3_rssi\n    numero(hr.hr20, 0)       // HR20 valor_cero\n];\n\nmsgEstado.tipo_sql = \"estado_actual_dispositivos\";\nmsgEstado.hr_original = hr;\nmsgEstado.mqtt_topic = msg.topic;\n\n\n// =======================================================\n// 6. ESTADO VISUAL DEL NODO\n// =======================================================\n\nnode.status({\n    fill: \"green\",\n    shape: \"dot\",\n    text: \"SQL HR listo ID \" + id_dispositivo\n});\n\n\n// =======================================================\n// 7. RETORNAR CUATRO SALIDAS\n// =======================================================\n//\n// Salida 1 → MariaDB antigua histórico\n// Salida 2 → MariaDB antigua estado actual\n// Salida 3 → MariaDB nueva histórico\n// Salida 4 → MariaDB nueva estado actual\n// =======================================================\n\n// Se crean copias para enviar lo mismo a ambas bases\nlet msgHistoricoAntigua = {\n    topic: msgHistorico.topic,\n    payload: msgHistorico.payload,\n    tipo_sql: \"historico_antigua\",\n    hr_original: msgHistorico.hr_original,\n    mqtt_topic: msgHistorico.mqtt_topic\n};\n\nlet msgEstadoAntigua = {\n    topic: msgEstado.topic,\n    payload: msgEstado.payload,\n    tipo_sql: \"estado_actual_antigua\",\n    hr_original: msgEstado.hr_original,\n    mqtt_topic: msgEstado.mqtt_topic\n};\n\nlet msgHistoricoNueva = {\n    topic: msgHistorico.topic,\n    payload: msgHistorico.payload,\n    tipo_sql: \"historico_nueva\",\n    hr_original: msgHistorico.hr_original,\n    mqtt_topic: msgHistorico.mqtt_topic\n};\n\nlet msgEstadoNueva = {\n    topic: msgEstado.topic,\n    payload: msgEstado.payload,\n    tipo_sql: \"estado_actual_nueva\",\n    hr_original: msgEstado.hr_original,\n    mqtt_topic: msgEstado.mqtt_topic\n};\n\nreturn [\n    msgHistoricoAntigua,\n    msgEstadoAntigua,\n    msgHistoricoNueva,\n    msgEstadoNueva\n];",
