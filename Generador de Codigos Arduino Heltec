/* =========================================================
   PANICO Y BOTON (NUEVA LOGICA DE RESPUESTA INSTANTANEA)
   ========================================================= */
static void handlePanicButton() {
  bool reading = (digitalRead(BUTTON_PIN) == LOW);
  uint32_t now = millis();

  if (reading != isPressingButton) {
    isPressingButton = reading;
    screenNeedsUpdate = true; // Pide refrescar la pantalla de inmediato
  }

  if (reading) {
    if (!buttonPrev) {
      buttonPressStart = now;
      buttonHeld = false;
    }
    // Si cumple los 1.5s
    if (!buttonHeld && (now - buttonPressStart) >= HOLD_TIME_MS) {
      buttonHeld = true;
      if (!panicActive) {
        panicActive = true; 
        panicEndMs = now + PANIC_DURATION_MS;
        
        isTxConfirmed = true; 
        confirmedNbTrials = 2;
        requestImmediateTx = true; 
        screenNeedsUpdate = true; 
      }
    }
  }

  buttonPrev = reading;
  
  if (panicActive && ((int32_t)(now - panicEndMs) >= 0)) {
    panicActive = false; 
    isTxConfirmed = false;
    requestImmediateTx = true; 
    screenNeedsUpdate = true;
  }
}

