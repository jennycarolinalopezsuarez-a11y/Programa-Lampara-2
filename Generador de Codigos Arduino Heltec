    def _set_entries_state(self, widget, state):
        for child in widget.winfo_children():
            try:
                if isinstance(child, ttk.Entry):
                    var_name = str(child.cget("textvariable"))
                    tracked = {str(self.dev_eui), str(self.app_eui), str(self.app_key)}
                    if var_name in tracked:
                        child.configure(state=state)
            except Exception:
                pass
            self._set_entries_state(child, state)

    def scan_ble_devices(self):
        if not self.ble_scan_enabled.get():
            messagebox.showinfo("BLE", "La búsqueda BLE está deshabilitada.")
            return

        try:
            from bleak import BleakScanner
            import asyncio
            import threading
        except Exception:
            messagebox.showerror("BLE", "No se encontró 'bleak'. Instálalo con: pip install bleak")
            self.write_log("BLE scan no disponible: falta paquete bleak.")
            return

        prefix = self.band_prefix.get().strip()
        self.write_log("Iniciando escaneo BLE de 8 segundos en hilo separado...")

        progress = tk.Toplevel(self.root)
        progress.title("Escaneo BLE")
        progress.geometry("360x120")
        progress.transient(self.root)
        progress.grab_set()
        ttk.Label(progress, text="Buscando bandas BLE...", font=("Segoe UI", 11, "bold")).pack(pady=(16, 8))
        status_lbl = ttk.Label(progress, text="Espera unos segundos.")
        status_lbl.pack()
        ttk.Progressbar(progress, mode="indeterminate", length=280).pack(pady=12)
        pb = progress.winfo_children()[-1]
        pb.start(10)

        def worker():
            async def do_scan():
                found = await BleakScanner.discover(timeout=8.0)
                items = []
                for d in found:
                    name = (d.name or "").strip()
                    mac = (d.address or "").strip().upper()
                    rssi = getattr(d, "rssi", None)
                    if prefix:
                        if name.startswith(prefix):
                            items.append((name, mac, rssi))
                    else:
                        items.append((name, mac, rssi))
                return items

            try:
                devices = asyncio.run(do_scan())
                self.root.after(0, lambda: self._finish_ble_scan(progress, devices, None))
            except Exception as e:
                self.root.after(0, lambda: self._finish_ble_scan(progress, None, e))

        threading.Thread(target=worker, daemon=True).start()

    def _finish_ble_scan(self, progress_window, devices, error):
        try:
            progress_window.grab_release()
            progress_window.destroy()
        except Exception:
            pass

        if error is not None:
            messagebox.showerror("BLE", f"Falló el escaneo BLE: {error}")
            self.write_log(f"ERROR BLE: {error}")
            return

        if not devices:
            messagebox.showinfo("BLE", "No se encontraron bandas con ese filtro.")
            self.write_log("No se encontraron dispositivos BLE compatibles.")
            return

        picker = tk.Toplevel(self.root)
        picker.title("Seleccionar banda BLE")
        picker.geometry("620x360")
        picker.transient(self.root)

        ttk.Label(picker, text="Selecciona la banda detectada:", font=("Segoe UI", 11, "bold")).pack(anchor="w", padx=10, pady=10)

        columns = ("name", "mac", "rssi")
        tree = ttk.Treeview(picker, columns=columns, show="headings", height=10)
        tree.heading("name", text="Nombre")
        tree.heading("mac", text="MAC")
        tree.heading("rssi", text="RSSI")
        tree.column("name", width=180)
        tree.column("mac", width=220)
        tree.column("rssi", width=80, anchor="center")
        tree.pack(fill="both", expand=True, padx=10, pady=6)

        for name, mac, rssi in devices:
            tree.insert("", "end", values=(name or "<sin nombre>", mac, "" if rssi is None else rssi))

        def use_selected():
            sel = tree.selection()
            if not sel:
                return
            vals = tree.item(sel[0], "values")
            self.band_name.set("" if vals[0] == "<sin nombre>" else vals[0])
            self.band_mac.set(vals[1])
            self.write_log(f"Banda seleccionada: {self.band_name.get() or '<sin nombre>'} / {self.band_mac.get()}")
            picker.destroy()

        btn_row = ttk.Frame(picker)
        btn_row.pack(fill="x", padx=10, pady=10)
        ttk.Button(btn_row, text="Usar selección", command=use_selected).pack(side="left")
        ttk.Button(btn_row, text="Cancelar", command=picker.destroy).pack(side="left", padx=8)

