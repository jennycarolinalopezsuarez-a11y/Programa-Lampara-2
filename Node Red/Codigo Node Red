    {
        "id": "096ff90ad0e7e2d6",
        "type": "function",
        "z": "9220fbd1493c7969",
        "name": "Filtro Kalman",
        "func": "let d = msg.payload_decoded || msg.payload;\n\nif (!d || !d.foto_A || !d.foto_B) return msg;\n\n// =======================================================\n// 1. MAPA LINEAL DEL TÚNEL\n// Minor = PK\n// Major = nivel\n// =======================================================\n\nconst mapaPK = {\n    0: 0,\n    20: 20,\n    40: 40,\n    60: 60,\n    80: 80,\n    100: 100\n};\n\nfunction calcularPeso(rssi) {\n    if (rssi === 0 || rssi < -95) return 0.01;\n    return Math.pow(10, ((rssi + 100) / 20));\n}\n\nfunction calcularPosicionLineal(foto) {\n    let sumaPesos = 0;\n    let sumaDistancia = 0;\n\n    for (let key in foto) {\n        let b = foto[key];\n\n        if (b && b.valid) {\n            // Ahora el PK viene desde el Minor.\n            // El Major ya no se usa para calcular la posición lineal.\n            let pk = Number(b.minor);\n\n            if (mapaPK[pk] !== undefined) {\n                let peso = calcularPeso(b.rssi);\n                sumaDistancia += mapaPK[pk] * peso;\n                sumaPesos += peso;\n            }\n        }\n    }\n\n    if (sumaPesos === 0) return null;\n    return sumaDistancia / sumaPesos;\n}\n\n// =======================================================\n// 1.1 OBTENER BEACON MÁS FUERTE\n// Major = nivel\n// Minor = PK\n// RSSI  = intensidad\n// =======================================================\n\nfunction obtenerBeaconMasFuerte(d) {\n    let beacons = [];\n\n    function agregar(foto) {\n        if (!foto) return;\n\n        for (let key in foto) {\n            let b = foto[key];\n\n            if (b && b.valid && b.rssi !== 0) {\n                beacons.push({\n                    major: Number(b.major),\n                    minor: Number(b.minor),\n                    rssi: Number(b.rssi)\n                });\n            }\n        }\n    }\n\n    // Foto B es la lectura más actual.\n    // Foto A queda como respaldo.\n    agregar(d.foto_B);\n    agregar(d.foto_A);\n\n    if (beacons.length === 0) return null;\n\n    // RSSI más alto = señal más fuerte.\n    // Ejemplo: -45 es más fuerte que -80.\n    beacons.sort((a, b) => b.rssi - a.rssi);\n\n    return beacons[0];\n}\n\nlet beaconFuerte = obtenerBeaconMasFuerte(d);\n\nlet major_actual = beaconFuerte ? beaconFuerte.major : null;\nlet minor_actual = beaconFuerte ? beaconFuerte.minor : null;\nlet rssi_beacon_mayor = beaconFuerte ? beaconFuerte.rssi : null;\n\n// =======================================================\n// 2. CÁLCULO DE POSICIÓN\n// =======================================================\n\nlet posA_cruda = calcularPosicionLineal(d.foto_A);\nlet posB_cruda = calcularPosicionLineal(d.foto_B);\n\n// Si no hay PK válido, no calculamos Kalman.\n// Pero igual dejamos guardado el nivel si existe un beacon válido.\nif (posB_cruda === null) {\n    msg.trayectoria = msg.trayectoria || {};\n\n    msg.trayectoria.major_actual = major_actual;\n    msg.trayectoria.nivel_actual = major_actual;\n    msg.trayectoria.minor_actual = minor_actual;\n    msg.trayectoria.pk_beacon_mas_fuerte = minor_actual;\n    msg.trayectoria.rssi_beacon_mayor = rssi_beacon_mayor;\n\n    node.status({\n        fill: \"yellow\",\n        shape: \"ring\",\n        text: `Sin PK válido | Nivel ${major_actual ?? \"-\"}`\n    });\n\n    return msg;\n}\n\n// =======================================================\n// 3. FILTRO DE KALMAN\n// =======================================================\n\nconst R = 8.0;\nconst Q = 0.5;\n\nlet kalmanKey = d.dev_eui || d.node_id || d.device_name || \"default\";\n\nlet x_est = context.get(\"kalman_x_\" + kalmanKey);\nlet P = context.get(\"kalman_P_\" + kalmanKey);\n\nif (x_est === undefined || x_est === null) {\n    x_est = posB_cruda;\n    P = 1.0;\n}\n\nlet x_pred = x_est;\nlet P_pred = P + Q;\n\nlet K = P_pred / (P_pred + R);\n\nx_est = x_pred + K * (posB_cruda - x_pred);\nP = (1 - K) * P_pred;\n\ncontext.set(\"kalman_x_\" + kalmanKey, x_est);\ncontext.set(\"kalman_P_\" + kalmanKey, P);\n\n// Limitar la posición dentro del túnel.\n// Si después usas PK mayores a 100, cambia este límite.\nx_est = Math.max(0, Math.min(100, x_est));\n\n// =======================================================\n// 4. TENDENCIA Y PREDICCIÓN POR TRAMO PK\n// =======================================================\n\nlet prediccion = x_est;\nlet estado_movimiento = \"Calculando...\";\n\nconst pks = [0, 20, 40, 60, 80, 100];\n\nlet pk_inferior = 0;\nlet pk_superior = 20;\n\nfor (let i = 0; i < pks.length - 1; i++) {\n    if (x_est >= pks[i] && x_est <= pks[i + 1]) {\n        pk_inferior = pks[i];\n        pk_superior = pks[i + 1];\n        break;\n    }\n}\n\nif (posA_cruda !== null) {\n    let diferencia = x_est - posA_cruda;\n\n    prediccion = Math.max(0, Math.min(100, x_est + diferencia));\n\n    if (diferencia > 2.0) {\n        estado_movimiento = `Saliendo del PK ${pk_inferior}, entrando al PK ${pk_superior}`;\n    } else if (diferencia < -2.0) {\n        estado_movimiento = `Saliendo del PK ${pk_superior}, entrando al PK ${pk_inferior}`;\n    } else {\n        let pk_cercano = (x_est - pk_inferior < pk_superior - x_est) ? pk_inferior : pk_superior;\n        estado_movimiento = `Detenido cerca del PK ${pk_cercano}`;\n    }\n}\n\n// =======================================================\n// 5. EMPAQUETAR RESULTADO\n// =======================================================\n\nmsg.trayectoria = {\n    metro_actual_crudo: parseFloat(posB_cruda.toFixed(2)),\n    metro_actual_kalman: parseFloat(x_est.toFixed(2)),\n    metro_prediccion: parseFloat(prediccion.toFixed(2)),\n    incertidumbre: parseFloat(P.toFixed(2)),\n    estado: estado_movimiento,\n\n    // Posición anterior desde Foto A\n    metro_anterior_crudo: posA_cruda !== null ? parseFloat(posA_cruda.toFixed(2)) : null,\n\n    // Alias para Mapear_Modbus_Multi y SQL\n    posicion_actual: parseFloat(x_est.toFixed(2)),\n    posicion_anterior: posA_cruda !== null ? parseFloat(posA_cruda.toFixed(2)) : null,\n    posicion_futura: parseFloat(prediccion.toFixed(2)),\n\n    // NUEVO:\n    // Major = nivel\n    // Minor = PK\n    major_actual: major_actual,\n    nivel_actual: major_actual,\n    minor_actual: minor_actual,\n    pk_beacon_mas_fuerte: minor_actual,\n    rssi_beacon_mayor: rssi_beacon_mayor\n};\n\n// Estado visual para confirmar que el filtro está enviando datos\nnode.status({\n    fill: \"green\",\n    shape: \"dot\",\n    text: `Nivel ${major_actual ?? \"-\"} | PK actual: ${msg.trayectoria.posicion_actual} m`\n});\n\nreturn msg;",
